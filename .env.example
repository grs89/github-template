# Application Environment
APP_ENV=development
APP_DEBUG=false
APP_LOG_LEVEL=INFO

# API Configuration
API_BASE_URL=http://localhost:8000
API_TIMEOUT=30
API_RETRIES=3

# Registry Configuration
REGISTRY_URL=ghcr.io
REGISTRY_USERNAME=
REGISTRY_TOKEN=
REGISTRY_NAMESPACE=your-org

# GitHub Configuration
GITHUB_TOKEN=
GITHUB_REPOSITORY=owner/repo
GITHUB_SERVER_URL=https://github.com

# Security Configuration
COSIGN_KEY_LOCATION=/etc/secrets/cosign.key
COSIGN_PASSWORD=

# Terraform & Infrastructure
TF_VAR_environment=development
TF_VAR_region=us-east-1
TF_VAR_project_name=github-template

# Database Configuration (if applicable)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=app_db

# Monitoring & Observability
LOG_LEVEL=INFO
TRACE_ENABLED=false
METRICS_ENABLED=false

# Report Generation
REPORT_OUTPUT_DIR=./reports
REPORT_FORMAT=pdf
INCLUDE_CHARTS=true

# Testing
TEST_ENV=true
TEST_TIMEOUT=60
PYTEST_MARKERS=unit
